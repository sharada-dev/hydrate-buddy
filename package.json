  "repository": {
    "type": "git",
    "url": "https://github.com/sharada-dev/hydrate-buddy.git"
  },
  "homepage": "https://github.com/sharada-dev/hydrate-buddy#readme",
  "dependencies": {
    "jimp": "0.22.12"
  },
  "devDependencies": {
    "electron": "^33.2.0"
  }
}
